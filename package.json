{
  "name": "spotcoin",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && NODE_ENV=production next build",
    "deploy": "rm -rf .netlify && prisma generate && netlify deploy --prod --build --skip-functions-cache --site 8ace60f2-3284-4523-8ee8-29aaa0433051",
    "deploy:trigger": "netlify deploy --prod --trigger --site 8ace60f2-3284-4523-8ee8-29aaa0433051",
    "deploy:upload": "netlify deploy --prod --skip-functions-cache --site 8ace60f2-3284-4523-8ee8-29aaa0433051",
    "netlify:build": "rm -rf .netlify && prisma generate && npm run build && netlify build",
    "deploy:split": "npm run netlify:build && npm run deploy:upload",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "seed:test-users": "node scripts/seed-test-users.js",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.6",
    "@netlify/functions": "^4.2.9",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@slack/bolt": "^4.7.1",
    "@slack/web-api": "^7.15.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "geist": "^1.5.1",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.542.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^6.19.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.4.2",
    "sanitize-html": "^2.17.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/sanitize-html": "^2.16.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.11",
    "@playwright/test": "^1.59.1",
    "dotenv-cli": "^11.0.0",
    "vitest": "^4.1.5"
  }
}
