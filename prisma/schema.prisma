generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum PayoutStatus {
  PENDING
  COMPLETED
}

enum CoinTransactionType {
  ALLOWANCE_GRANT
  RECOGNITION_SENT
  RECOGNITION_RECEIVED
  BONUS_GRANT
  PAYOUT
}

enum PayoutWindowStatus {
  OPEN
  CLOSED
}

enum PollKind {
  POLL
  AWARD
}

enum PollResultVisibility {
  AUTO_AFTER_END
  MANUAL
}

enum RsvpStatus {
  GOING
  INTERESTED
  NOT_GOING
}

enum PayoutRequestCurrency {
  NGN
  GHS
}

enum PayoutRequestDecisionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Workspace {
  id                  String   @id @default(cuid())
  name                String
  companyLegalName    String?
  monthlyAllowance    Int      @default(5)
  tokenValueNaira     Int      @default(1000)
  tokenValueGhs       Int      @default(0)
  slackTeamId         String?  @unique
  slackBotToken       String?
  targetChannelId     String?
  recognitionSchedule String   @default("EVERY_FRIDAY")
  timezone            String   @default("Africa/Lagos")
  onboardingComplete  Boolean  @default(false)
  createdAt           DateTime @default(now())
  users               User[]
  values              CompanyValue[]
  positions           Position[]
  recognitions        Recognition[]
  payoutWindows       PayoutWindow[]
  polls               Poll[]
  workspaceEvents     WorkspaceEvent[]
  payoutRequests      PayoutRequest[]
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  name                 String
  username             String?
  passwordHash         String
  avatarUrl            String?
  role                 Role              @default(EMPLOYEE)
  workspaceId          String
  workspace            Workspace         @relation(fields: [workspaceId], references: [id])
  slackUserId          String?
  positionId           String?
  position             Position?         @relation(fields: [positionId], references: [id])
  coinsToGive          Int               @default(5)
  spotTokensEarned     Int               @default(0)
  payoutBankName            String?
  payoutBankAccountName   String?
  payoutBankAccountNumber String?
  payoutStatus         PayoutStatus      @default(PENDING)
  lastActiveAt         DateTime?
  deletedAt            DateTime?
  createdAt            DateTime          @default(now())
  sentRecognitions     Recognition[]     @relation("SentRecognitions")
  receivedRecognitions Recognition[]     @relation("ReceivedRecognitions")
  coinTransactions     CoinTransaction[]
  openedPayoutWindows  PayoutWindow[]    @relation("PayoutWindowOpenedBy")
  passwordResetTokens  PasswordResetToken[]
  pollsCreated         Poll[]            @relation("PollsCreated")
  awardPollOptions     PollOption[]      @relation("AwardPollOptions")
  pollVotes            PollVote[]        @relation("PollVotes")
  workspaceEventsCreated WorkspaceEvent[] @relation("WorkspaceEventsCreated")
  eventRsvps           EventRsvp[]       @relation("EventRsvps")
  eventComments        EventComment[]    @relation("EventComments")
  payoutRequestsCreated PayoutRequest[]  @relation("PayoutRequestUser")
  payoutRequestsResolved PayoutRequest[] @relation("PayoutRequestResolvedBy")

  @@unique([workspaceId, username])
  @@index([workspaceId])
  @@index([positionId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model CompanyValue {
  id           String        @id @default(cuid())
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  name         String
  emoji        String
  isActive     Boolean       @default(true)
  recognitions Recognition[]

  @@index([workspaceId])
}

model Position {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  users       User[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Recognition {
  id          String       @id @default(cuid())
  senderId    String
  sender      User         @relation("SentRecognitions", fields: [senderId], references: [id])
  recipientId String
  recipient   User         @relation("ReceivedRecognitions", fields: [recipientId], references: [id])
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  valueId     String
  value       CompanyValue @relation(fields: [valueId], references: [id])
  message     String
  coinAmount  Int
  slackTs     String?
  createdAt   DateTime     @default(now())

  @@index([workspaceId])
  @@index([senderId])
  @@index([recipientId])
}

model CoinTransaction {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  workspaceId String
  type        CoinTransactionType
  amount      Int
  referenceId String?
  createdAt   DateTime            @default(now())

  @@index([userId])
  @@index([workspaceId])
}

model SlackInstallation {
  id            String   @id @default(cuid())
  workspaceId   String   @unique
  slackTeamId   String   @unique
  botToken      String
  botUserId     String
  installedById String
  createdAt     DateTime @default(now())
}

model PayoutWindow {
  id         String             @id @default(cuid())
  workspaceId String             @unique
  workspace  Workspace          @relation(fields: [workspaceId], references: [id])
  openedById String
  openedBy   User               @relation("PayoutWindowOpenedBy", fields: [openedById], references: [id])
  openedAt   DateTime           @default(now())
  status     PayoutWindowStatus @default(OPEN)

  @@index([workspaceId])
}

model Poll {
  id               String               @id @default(cuid())
  workspaceId      String
  workspace        Workspace            @relation(fields: [workspaceId], references: [id])
  createdById      String
  createdBy        User                 @relation("PollsCreated", fields: [createdById], references: [id])
  kind             PollKind             @default(POLL)
  title            String
  description      String?
  multiSelect      Boolean              @default(false)
  startsAt         DateTime
  endsAt           DateTime
  resultVisibility PollResultVisibility @default(AUTO_AFTER_END)
  resultsVisible   Boolean              @default(false)
  votesAnonymous   Boolean              @default(false)
  closedAt         DateTime?
  createdAt        DateTime             @default(now())
  options          PollOption[]
  votes            PollVote[]

  @@index([workspaceId])
  @@index([endsAt])
}

model PollOption {
  id           String     @id @default(cuid())
  pollId       String
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label        String
  optionUserId String?
  optionUser   User?      @relation("AwardPollOptions", fields: [optionUserId], references: [id])
  sortOrder    Int        @default(0)
  votes        PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation("PollVotes", fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  @@unique([pollId, userId, optionId])
  @@index([pollId])
  @@index([userId])
}

model WorkspaceEvent {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id])
  createdById   String
  createdBy     User          @relation("WorkspaceEventsCreated", fields: [createdById], references: [id])
  title         String
  description   String?
  location      String?
  venue         String?
  coverImageUrl String?
  linkUrl       String?
  startsAt      DateTime
  endsAt        DateTime?
  createdAt     DateTime      @default(now())
  rsvps         EventRsvp[]
  comments      EventComment[]

  @@index([workspaceId])
  @@index([startsAt])
}

model EventRsvp {
  eventId   String
  userId    String
  status    RsvpStatus
  createdAt DateTime       @default(now())
  event     WorkspaceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User           @relation("EventRsvps", fields: [userId], references: [id])

  @@id([eventId, userId])
  @@index([eventId])
}

model EventComment {
  id        String         @id @default(cuid())
  eventId   String
  userId    String
  message   String
  createdAt DateTime       @default(now())
  event     WorkspaceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User           @relation("EventComments", fields: [userId], references: [id])

  @@index([eventId])
}

model PayoutRequest {
  id                   String                     @id @default(cuid())
  workspaceId        String
  workspace            Workspace                  @relation(fields: [workspaceId], references: [id])
  userId               String
  user                 User                       @relation("PayoutRequestUser", fields: [userId], references: [id])
  tokenAmount          Int
  currency             PayoutRequestCurrency
  status               PayoutRequestDecisionStatus @default(PENDING)
  snapshotBankName         String?
  snapshotBankNumber       String?
  snapshotBankInstitution  String?
  createdAt            DateTime                   @default(now())
  resolvedAt           DateTime?
  resolvedById         String?
  resolvedBy           User?                      @relation("PayoutRequestResolvedBy", fields: [resolvedById], references: [id])

  @@index([workspaceId])
  @@index([userId])
  @@index([status])
}
